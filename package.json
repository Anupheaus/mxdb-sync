{
  "name": "@anupheaus/mxdb-sync",
  "version": "0.0.1",
  "main": "./dist/server.js",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.mjs",
        "require": "./dist/server.js"
      },
      "default": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.mjs",
        "require": "./dist/client.js"
      }
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.mjs",
      "require": "./dist/common.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/server.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "client": [
        "./dist/client.d.ts"
      ],
      "common": [
        "./dist/common.d.ts"
      ]
    }
  },
  "repository": "https://github.com/Anupheaus/mxdb-sync.git",
  "description": "MXDB-Sync",
  "author": "Anupheaus",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "start": "webpack --mode development",
    "server": "webpack --mode development --name server",
    "client": "webpack --mode development --name client --profile",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:crud": "vitest run --config vitest.e2e.config.ts --mode crud",
    "test:performance": "vitest run --config vitest.e2e.config.ts --mode performance",
    "test:stress": "vitest run --config vitest.e2e.config.ts --mode stress",
    "test:all": "node scripts/run-all-tests.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "agent.md"
  ],
  "typings": "./dist/server.d.ts",
  "dependencies": {
    "@anupheaus/common": "^0.1.29",
    "@anupheaus/react-ui": "^0.0.66",
    "@anupheaus/socket-api": "^0.0.28",
    "@faker-js/faker": "^8.4.1",
    "@sqlite.org/sqlite-wasm": "3.51.2-build8",
    "dotenv": "^16.4.5",
    "koa": "^2.14.1",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^12.0.1",
    "luxon": "^3.2.1",
    "mongodb": "^6.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sift": "^17.1.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-router": "^7.4.8",
    "@types/koa-static": "^4.0.4",
    "@types/luxon": "^3.2.0",
    "@types/node": "^20.8.2",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.19.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "koa-pug": "^5.1.1",
    "koa-static": "^5.0.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon-webpack-plugin": "^4.8.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "progress-webpack-plugin": "^1.0.16",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "util": "^0.12.5",
    "vitest": "^1.2.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-inject-plugin": "^1.5.5",
    "webpack-node-externals": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "@anupheaus/common": "file:../common",
      "@anupheaus/react-ui": "file:../react-ui",
      "@anupheaus/socket-api": "file:../socket-api"
    }
  }
}
